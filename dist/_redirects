/ja/shuttle    /index.html  200
/ko/shuttle    /index.html  200
/ru/shuttle    /index.html  200
/ar/shuttle    /index.html  200
/de/shuttle    /index.html  200
/fr/shuttle    /index.html  200
/es/shuttle    /index.html  200
/id/shuttle    /index.html  200
/hi/shuttle    /index.html  200
/vi/shuttle    /index.html  200

